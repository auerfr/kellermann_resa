{
  "name": "Kellermann Resa",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt && python manage.py migrate && python manage.py loaddata temple_project/fixtures/initial_data.json",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Django Server",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "batisteo.vscode-django",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.tabSize": 4
      }
    }
  }
}
